{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/forecast/refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/briefing/generate",
      "schedule": "0 11 * * *"
    }
  ],
  "functions": {
    "app/api/forecast/refresh/route.ts": {
      "maxDuration": 60
    },
    "app/api/briefing/generate/route.ts": {
      "maxDuration": 60
    }
  }
}
